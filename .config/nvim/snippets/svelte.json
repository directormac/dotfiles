{
  "SvelteKit Remote Query": {
    "prefix": "skquery",
    "body": [
      "import { query } from '$app/server';",
      "",
      "export const ${1:getData} = query(async () => {",
      "\t$0",
      "});"
    ],
    "description": "SvelteKit Remote Query"
  },
  "SvelteKit Remote Query (Validated)": {
    "prefix": "skqueryv",
    "body": [
      "import { query } from '$app/server';",
      "import * as v from 'valibot';",
      "",
      "export const ${1:getData} = query(${2:v.string()}, async (${3:arg}) => {",
      "\t$0",
      "});"
    ],
    "description": "SvelteKit Remote Query with validation"
  },
  "SvelteKit Remote Form": {
    "prefix": "skform",
    "body": [
      "import { form } from '$app/server';",
      "import * as v from 'valibot';",
      "",
      "export const ${1:actionName} = form(",
      "\tv.object({",
      "\t\t${2:field}: v.string(),",
      "\t}),",
      "\tasync (${3:data}) => {",
      "\t\t$0",
      "\t}",
      ");"
    ],
    "description": "SvelteKit Remote Form"
  },
  "SvelteKit Remote Command": {
    "prefix": "skcommand",
    "body": [
      "import { command } from '$app/server';",
      "import * as v from 'valibot';",
      "",
      "export const ${1:commandName} = command(${2:v.string()}, async (${3:arg}) => {",
      "\t$0",
      "});"
    ],
    "description": "SvelteKit Remote Command"
  },
  "SvelteKit Remote Prerender": {
    "prefix": "skprerender",
    "body": [
      "import { prerender } from '$app/server';",
      "",
      "export const ${1:getStaticData} = prerender(async () => {",
      "\t$0",
      "});"
    ],
    "description": "SvelteKit Remote Prerender"
  },
  "Svelte Component Boilerplate": {
    "prefix": "sv-comp",
    "body": [
      "<script lang=\"ts\">",
      "\timport type { Snippet } from 'svelte';",
      "",
      "\tlet { children }: { children: Snippet<[]> } = \\$props();",
      "</script>",
      "",
      "{@render children()}",
      "$0"
    ],
    "description": "Full Svelte 5 component with typed children"
  },
  "Svelte Runes $state": {
    "prefix": "state",
    "body": "let ${1:name} = \\$state(${2:initialValue});",
    "description": "Svelte 5 state rune"
  },
  "Svelte Runes $state.raw": {
    "prefix": "stateraw",
    "body": "let ${1:name} = \\$state.raw(${2:initialValue});",
    "description": "Svelte 5 state.raw rune"
  },
  "Svelte Runes $derived": {
    "prefix": "derived",
    "body": "let ${1:name} = \\$derived(${2:expression});",
    "description": "Svelte 5 derived rune"
  },
  "Svelte Runes $derived.by": {
    "prefix": "derivedby",
    "body": [
      "let ${1:name} = \\$derived.by(() => {",
      "\t$0",
      "});"
    ],
    "description": "Svelte 5 derived.by rune"
  },
  "Svelte Runes $effect": {
    "prefix": "effect",
    "body": [
      "\\$effect(() => {",
      "\t$0",
      "});"
    ],
    "description": "Svelte 5 effect rune"
  },
  "Svelte Runes $props": {
    "prefix": "props",
    "body": "let { ${1:prop} } = \\$props();",
    "description": "Svelte 5 props rune"
  },
  "Svelte Runes $bindable": {
    "prefix": "bind",
    "body": "let { ${1:prop} = \\$bindable() } = \\$props();",
    "description": "Svelte 5 bindable prop"
  },
  "Svelte Runes $inspect": {
    "prefix": "inspect",
    "body": "\\$inspect(${1:value});",
    "description": "Svelte 5 inspect rune"
  },
  "Svelte Markup Each": {
    "prefix": "each",
    "body": [
      "{#each ${1:items} as ${2:item}}",
      "\t$0",
      "{/each}"
    ],
    "description": "Svelte each block"
  },
  "Svelte Markup If": {
    "prefix": "if",
    "body": [
      "{#if ${1:condition}}",
      "\t$0",
      "{/if}"
    ],
    "description": "Svelte if block"
  },
  "Svelte Markup Snippet": {
    "prefix": "snip",
    "body": [
      "{@snippet ${1:name}(${2:args})}",
      "\t$0",
      "{/snippet}"
    ],
    "description": "Svelte 5 snippet definition"
  },
  "Svelte Boundary": {
    "prefix": "sbound",
    "body": [
      "<svelte:boundary>",
      "\t$0",
      "\t{#snippet failed(error, reset)}",
      "\t\t<p>{error.message} <button onclick={reset}>Retry</button></p>",
      "\t{/snippet}",
      "\t{#snippet loading()}",
      "\t\t<p>Loading...</p>",
      "\t{/snippet}",
      "</svelte:boundary>"
    ],
    "description": "Svelte boundary with failed and loading snippets"
  },
  "Accordion": {
